# ─── Database ────────────────────────────────────────────────────────────────
# Supabase Session Pooler URL (port 5432)
DATABASE_URL=postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# ─── Redis (Upstash — TLS required) ─────────────────────────────────────────
# Must start with rediss:// (double-s = TLS)
REDIS_URL=rediss://default:[YOUR-TOKEN]@YOUR-HOST.upstash.io:6379

# Enable Medusa caching feature (required for caching-redis to activate)
MEDUSA_FF_CACHING=true

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated — add Render + Vercel URLs before production
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000

# ─── Security ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=

# ─── Medusa Worker ───────────────────────────────────────────────────────────
# "shared" = server + worker in one process (suitable for Render free tier)
# "server" = API only | "worker" = background jobs only
MEDUSA_WORKER_MODE=shared

# ─── Admin ───────────────────────────────────────────────────────────────────
# Set to your Render backend URL in production
MEDUSA_ADMIN_BACKEND_URL=http://localhost:9000

# ─── Node ────────────────────────────────────────────────────────────────────
NODE_ENV=development
